scenario: incident-briefing-periodic-surprise
world: periodic-surprise every_events=2
initial_instant: 2026-05-18T12:00:00.000Z
cassette: ./c5-periodic-surprise.local-deterministic.json

sources:
  - id=incident-feed payload_hash=sha256:1111111111111111111111111111111111111111111111111111111111111111

script:
  - at=0m ingest=bootstrap source=incident-feed
  - at=15m tick=evidence-age
  - at=30m ingest=incident-opened source=incident-feed status=red open_incident_count=1
  - at=45m tick=evidence-age

expect:
  - relationship=periodic-material-change profile=periodic-surprise total=1
  - relationship=no-network-or-live-model-calls network_calls=0 live_model_calls=0
  - relationship=event-change-forces-fresh-rejudge fresh_receipts=2 memo_hit_receipts=2
