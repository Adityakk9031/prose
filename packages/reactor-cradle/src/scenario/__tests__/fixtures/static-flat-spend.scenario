scenario: incident-briefing-flat-spend
world: static
initial: 2026-05-18T12:00:00Z
cassette: ./cassettes/incident-briefing.replay.json

sources:
  - id=incident-channel kind=synthetic fixture=incident-channel.static
  - id=status-page kind=synthetic fixture=status-page.static

script:
  - at=0m ingest=bootstrap source=incident-channel
  - at=15m tick
  - at=15m read=incident-channel
  - at=6h model=judge prompt=review-static-world
  - at=24h tick
  - at=24h read=status-page

expect:
  - relationship=static-surprise-zero scope=world
  - relationship=hands-free-replay cassette=required
  - relationship=tokens-flat-after-bootstrap fresh=0
  - relationship=every-token-has-surprise-cause required=true
